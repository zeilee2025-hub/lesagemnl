{
  "cleanUrls": true,

  "headers": [
    {
      "source": "/maintenance.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/maintenance.html",
      "destination": "/maintenance.html"
    },
    {
      "source": "/(.*)",
      "destination": "/maintenance.html"
    }
  ]
}